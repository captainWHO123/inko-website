---
---

<header class="header" id="site-header">
  <div class="header-inner">
    <a href="#hero" class="header-logo">
      <img src="/logo_lightmode.svg" alt="Inko" id="header-logo-img">
    </a>

    <div class="header-desktop">
      <nav class="header-nav">
        <a href="#features">Features</a>
        <a href="#how-to-use">How to Use</a>
        <a href="#security">Security</a>
        <a href="#faq">FAQ</a>
      </nav>

      <div class="header-form">
        <label class="sr-only" for="nav-work-email">Work email address</label>
        <input id="nav-work-email" class="header-input" placeholder="Enter Your Work Email" type="email">
        <button class="header-cta-btn" type="button" id="nav-submit-btn">Get Early Access</button>
      </div>
    </div>

    <button class="header-mobile-btn" id="mobile-menu-toggle" type="button" aria-label="Open navigation menu">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <div class="header-mobile-panel" id="mobile-menu-panel">
    <a href="#features">Features</a>
    <a href="#how-to-use">How to Use</a>
    <a href="#security">Security</a>
    <a href="#faq">FAQ</a>
    <div class="header-mobile-form">
      <input type="email" placeholder="Enter Your Work Email" id="mobile-email-input">
      <button type="button" id="mobile-submit-btn">Get Early Access</button>
    </div>
  </div>
</header>

<style is:global>
/* ── Header ── */
.header { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: transparent; backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); transition: background-color 0.3s; }
.header.scrolled { background-color: rgba(255,255,255,0); }
.header-inner {
  max-width: 1160px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.625rem 1.5rem;
}

.header-logo img { height: 1.25rem; width: auto; }

.header-desktop { display: none; align-items: center; gap: 2rem; }
@media (min-width: 1024px) { .header-desktop { display: flex; } }
.header-nav { display: flex; align-items: center; gap: 2rem; font-size: 0.82rem; font-weight: 700; color: #07111f; }
.header-nav a { text-decoration: none; color: inherit; transition: color 0.15s; }
.header-nav a:hover { color: #1d8dff; }

.header-form { display: flex; align-items: center; gap: 0; border-radius: 0.5rem; background: rgba(255,255,255,0.7); padding: 0.25rem; }
.header-input {
  height: 36px; width: 160px; padding: 0 0.75rem;
  border: none; background: transparent;
  font-size: 0.78rem; font-weight: 600; color: #17243a; outline: none;
}
@media (min-width: 1024px) { .header-input { width: 200px; } }
.header-input::placeholder { color: #8b9aaa; }
.header-cta-btn {
  display: inline-flex; align-items: center; justify-content: center;
  border-radius: 0.5rem; background: #1f8fff; color: #fff; border: none;
  padding: 0.5rem 0.75rem; font-size: 0.78rem; font-weight: 800; cursor: pointer;
  transition: background 0.15s; font-family: inherit;
}
.header-cta-btn:hover { background: #117dea; }

/* Mobile hamburger */
.header-mobile-btn {
  display: flex; width: 40px; height: 40px; align-items: center; justify-content: center;
  border: none; background: none; cursor: pointer; color: #07111f; border-radius: 0.5rem;
}
.header-mobile-btn:hover { color: #1d8dff; }
@media (min-width: 1024px) { .header-mobile-btn { display: none; } }
.header-mobile-btn svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

/* Mobile menu panel */
.header-mobile-panel {
  display: none; margin-top: 0.75rem; border-radius: 1rem; border: 1px solid rgba(0,0,0,0.06);
  background: rgba(255,255,255,0.96); padding: 1rem; box-shadow: 0 18px 48px rgba(0,0,0,0.12);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
}
.header-mobile-panel.open { display: block; }
.header-mobile-panel a { display: block; padding: 0.5rem 0; font-size: 0.88rem; font-weight: 700; color: #07111f; text-decoration: none; }
.header-mobile-panel a:hover { color: #1d8dff; }
.header-mobile-form { margin-top: 1rem; background: rgba(0,0,0,0.04); border-radius: 0.75rem; padding: 0.75rem; }
.header-mobile-form input {
  width: 100%; height: 36px; border: none; background: transparent; padding: 0 0.5rem;
  font-size: 0.82rem; font-weight: 600; color: #17243a; outline: none; font-family: inherit;
}
.header-mobile-form input::placeholder { color: #8b9aaa; }
.header-mobile-form button {
  width: 100%; margin-top: 0.5rem; height: 36px; border-radius: 0.5rem; background: #1f8fff; border: none;
  font-size: 0.82rem; font-weight: 800; color: #fff; cursor: pointer; font-family: inherit;
}
.header-mobile-form button:hover { background: #117dea; }
</style>

<script>
// ── Scroll effect ──
const header = document.getElementById('site-header');
const logoImg = document.getElementById('header-logo-img') as HTMLImageElement | null;

function onScroll() {
  if (!header) return;
  if (window.scrollY > 60) {
    header.classList.add('scrolled');
  } else {
    header.classList.remove('scrolled');
  }
  if (logoImg) {
    logoImg.src = '/logo_lightmode.svg';
  }
}
window.addEventListener('scroll', onScroll, { passive: true });
onScroll();

// ── Mobile menu toggle ──
const menuToggle = document.getElementById('mobile-menu-toggle');
const menuPanel = document.getElementById('mobile-menu-panel');

const hamburgerSVG = '<svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
const closeSVG = '<svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

menuToggle?.addEventListener('click', () => {
  if (!menuPanel) return;
  menuPanel.classList.toggle('open');
  if (menuToggle) {
    menuToggle.innerHTML = menuPanel.classList.contains('open') ? closeSVG : hamburgerSVG;
  }
});
</script>
