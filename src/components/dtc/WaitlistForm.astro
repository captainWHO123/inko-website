---
interface Props {
  id: string;
  location: string;
  layout?: 'inline' | 'stacked';
  placeholder?: string;
  buttonLabel?: string;
  dark?: boolean;
}

const {
  id,
  location,
  layout = 'inline',
  placeholder = 'Enter Your Work Email',
  buttonLabel = 'Join Waitlist',
  dark = false,
} = Astro.props;
---

<form
  id={id}
  class:list={['dtc-waitlist-form', `dtc-waitlist-form--${layout}`, dark && 'dtc-waitlist-form--dark', 'js-waitlist-form']}
  data-location={location}
  novalidate
>
  <label class="sr-only" for={`${id}-email`}>Work email</label>
  <input id={`${id}-email`} name="email" placeholder={placeholder} type="email" autocomplete="email" required />
  <button type="submit">{buttonLabel}</button>
  <p class="dtc-form-message" role="status" aria-live="polite"></p>
</form>
