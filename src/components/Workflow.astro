---
---

<section id="how-to-use" class="workflow-section">
  <div style="max-width:1160px;margin:0 auto;">
    <p class="workflow-label">How Inko Works</p>
    <h2 class="workflow-h2">One Device.<br>All Your Conversations.</h2>

    <div class="workflow-grid">
      <!-- Step 1 -->
      <article class="workflow-step">
        <div class="step-inner">
          <span class="step-number">1</span>
          <div>
            <h3 class="step-title">Capture</h3>
            <p class="step-body">Record a meeting, call, or in-person consultation from your phone and a Recorder pen.</p>
          </div>
        </div>
        <div style="margin-top:1.5rem;display:flex;align-items:center;padding-left:calc((100% - 13.8rem) / 2 + 2.5rem);">
          <div class="mini-phone" style="flex-shrink:0;">
            <div class="mini-phone-screen">
              <p class="mini-phone-title">Recording</p>
              <p class="mini-phone-subtitle">Consulting client call</p>
              <div class="mini-waveform">
                <span class="mini-waveform-bar" style="height:12px;"></span>
                <span class="mini-waveform-bar" style="height:22px;"></span>
                <span class="mini-waveform-bar" style="height:34px;"></span>
                <span class="mini-waveform-bar" style="height:18px;"></span>
                <span class="mini-waveform-bar" style="height:28px;"></span>
                <span class="mini-waveform-bar" style="height:38px;"></span>
                <span class="mini-waveform-bar" style="height:20px;"></span>
              </div>
              <div class="mini-record-btn"><div class="mini-record-btn-inner"></div></div>
            </div>
          </div>
          <img src="/pen-icon.png" alt="Pen" style="margin-left:0.2rem;height:16rem;flex-shrink:0;transform:rotate(-20deg);">
        </div>
      </article>

      <!-- Step 2 -->
      <article class="workflow-step">
        <div class="step-inner" style="padding-left:0.75rem;">
          <span class="step-number">2</span>
          <div>
            <h3 class="step-title">Structure</h3>
            <p class="step-body">Inko extracts what matters so you do not have to rebuild it from memory.</p>
          </div>
        </div>
        <div style="margin-top:1.5rem;display:flex;justify-content:center;">
          <div class="mini-phone">
            <div class="mini-phone-screen light">
              <div class="mini-phone-notch"></div>
              <p class="mini-phone-title" style="color:#17243a;">Anna Johnson</p>
              <p class="mini-phone-subtitle">Policy review</p>
              <div class="mini-summary-cards">
                <div class="mini-summary-card">
                  <p style="font-size:0.42rem;font-weight:800;color:#17243a;">Key needs</p>
                  <div class="mini-summary-card-line" style="width:48px;"></div>
                  <div class="mini-summary-card-line" style="width:36px;"></div>
                </div>
                <div class="mini-summary-card">
                  <p style="font-size:0.42rem;font-weight:800;color:#17243a;">Concerns</p>
                  <div class="mini-summary-card-line" style="width:48px;"></div>
                  <div class="mini-summary-card-line" style="width:36px;"></div>
                </div>
                <div class="mini-summary-card">
                  <p style="font-size:0.42rem;font-weight:800;color:#17243a;">Next step</p>
                  <div class="mini-summary-card-line" style="width:48px;"></div>
                  <div class="mini-summary-card-line" style="width:36px;"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>

      <!-- Step 3 -->
      <article class="workflow-step">
        <div class="step-inner">
          <span class="step-number">3</span>
          <div>
            <h3 class="step-title">Act</h3>
            <p class="step-body">Get follow-ups, next steps, updated records, and move the client forward.</p>
          </div>
        </div>
        <div style="margin-top:1.5rem;display:flex;justify-content:center;">
          <div class="mini-phone">
            <div class="mini-phone-screen light">
              <div class="mini-phone-notch"></div>
              <p class="mini-phone-title" style="color:#17243a;font-size:0.58rem;">Follow-up Ready</p>
              <div style="margin-top:8px;border-radius:0.56rem;border:1px solid #e5edf6;background:#f8fbff;padding:8px;">
                <div style="height:4px;width:64px;border-radius:999px;background:#c8dbea;"></div>
                <div style="height:4px;width:56px;border-radius:999px;background:#c8dbea;margin-top:4px;"></div>
                <div style="height:4px;width:48px;border-radius:999px;background:#c8dbea;margin-top:4px;"></div>
              </div>
              <p style="margin-top:12px;font-size:0.48rem;font-weight:800;color:#17243a;">Next Steps</p>
              <div style="margin-top:6px;display:flex;flex-direction:column;gap:6px;">
                <div style="height:16px;border-radius:6px;background:#eef6ff;"></div>
                <div style="height:16px;border-radius:6px;background:#eef6ff;"></div>
                <div style="height:16px;border-radius:6px;background:#eef6ff;"></div>
              </div>
              <button style="margin-top:16px;height:20px;width:100%;border-radius:7px;background:#1f8fff;border:none;font-size:0.34rem;font-weight:800;color:#fff;font-family:inherit;">Draft email</button>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style is:global>
/* ── Workflow Section ── */
.workflow-section { background: #fff; padding: 4rem 1.25rem 4rem; }
@media (min-width: 640px) { .workflow-section { padding: 6rem 2rem 6rem; } }
.workflow-label {
  text-align: center; font-size: 0.78rem; font-weight: 800;
  text-transform: uppercase; letter-spacing: 0.12em; color: #263142;
}
.workflow-h2 {
  max-width: 45rem; margin: 0.5rem auto 0;
  text-align: center; font-size: 2rem; font-weight: 800; line-height: 1.03;
  letter-spacing: -0.02em; color: #07111f;
}
@media (min-width: 640px) { .workflow-h2 { font-size: 2.85rem; } }
.workflow-grid {
  position: relative; max-width: 1160px; margin: 1.25rem auto 0;
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;
}
@media (max-width: 520px) { .workflow-grid { grid-template-columns: 1fr; } }

.flow-arrow {
  position: absolute; display: block; height: 96px; width: 224px;
  border-top: 2px dashed #65b5df; pointer-events: none;
}
@media (max-width: 520px) { .flow-arrow { display: none; } }

.workflow-step { position: relative; text-align: center; }
.step-inner {
  display: flex; max-width: 13.8rem; margin: 0 auto; align-items: flex-start; gap: 0.75rem; text-align: left;
}
.step-number {
  display: flex; width: 28px; height: 28px; flex-shrink: 0;
  align-items: center; justify-content: center;
  border-radius: 999px; background: #1f8fff;
  font-size: 0.78rem; font-weight: 800; color: #fff;
  box-shadow: 0 12px 24px -14px rgba(31,143,255,0.8);
}
.step-title { font-size: 1.02rem; font-weight: 800; line-height: 1; color: #07111f; }
.step-body { margin-top: 0.5rem; font-size: 0.74rem; font-weight: 600; line-height: 1.32; color: #111b2a; }

/* ── Mini Phones ── */
.mini-phone {
  position: relative; width: 7.15rem; aspect-ratio: 9 / 18.5;
  border-radius: 1.1rem; background: #000; padding: 4px;
  box-shadow: 0 20px 34px -22px rgba(9,21,42,0.48);
}
.mini-phone-screen {
  height: 100%; border-radius: 0.86rem; padding: 16px 8px 20px;
  text-align: center; color: #fff; background: #05080c;
}
.mini-phone-screen.light { background: #fff; color: #17243a; }
.mini-phone-notch { width: 36px; height: 8px; border-radius: 999px; background: #000; margin: 0 auto 12px; }
.mini-phone-title { font-size: 0.52rem; font-weight: 800; }
.mini-phone-subtitle { font-size: 0.34rem; color: rgba(255,255,255,0.54); margin-top: 4px; }
.light .mini-phone-subtitle { color: #8ca0b5; }
.mini-waveform { display: flex; height: 40px; align-items: center; justify-content: center; gap: 4px; margin-top: 36px; }
.mini-waveform-bar { width: 4px; border-radius: 999px; background: rgba(255,255,255,0.34); }
.mini-record-btn {
  display: flex; width: 32px; height: 32px; margin: 36px auto 0;
  align-items: center; justify-content: center;
  border-radius: 999px; border: 1px solid rgba(255,255,255,0.7); background: #ef3030;
}
.mini-record-btn-inner { width: 20px; height: 20px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.8); }
.mini-summary-cards { margin-top: 12px; display: flex; flex-direction: column; gap: 6px; }
.mini-summary-card { border-radius: 0.5rem; border: 1px solid #e4edf6; background: #f8fbff; padding: 6px; }
.mini-summary-card-title { font-size: 0.42rem; font-weight: 800; }
.mini-summary-card-line { height: 4px; border-radius: 999px; background: #d8e7f5; margin-top: 4px; }
.mini-summary-card-line-accent { background: rgba(31,143,255,0.3); }
.mini-phone-step { margin-top: 1.5rem; }
</style>
