---
---

<section class="hero-section">
  <div class="hero-content">
    <h1 class="hero-h1">
      Turn Client Talks into Action.
    </h1>

    <p class="hero-sub">
      <em style="color:#1f8fff;">No notes, no delays.</em> Inko captures every detail of your in-person meetings — from full records to follow-up drafts. Focus on the client, and leave the paperwork to us.
    </p>

    <div id="early-access" class="hero-form-wrap">
      <form class="early-access-form" id="hero-form">
        <label class="sr-only" for="hero-email">Work email address</label>
        <input id="hero-email" class="early-access-input" name="workEmail" placeholder="Work email address" required type="email">
        <button class="early-access-btn" type="submit">Get Early Access</button>
        <div id="hero-form-message" class="form-message" style="display:none;"></div>
      </form>
    </div>

    <div class="advisor-proof">
      <div class="advisor-avatars">
        <img src="/avatars/avatar-1.jpg" alt="" class="advisor-avatar" style="object-fit:cover;z-index:4;">
        <img src="/avatars/avatar-2.jpg" alt="" class="advisor-avatar" style="object-fit:cover;z-index:3;">
        <img src="/avatars/avatar-3.jpg" alt="" class="advisor-avatar" style="object-fit:cover;z-index:2;">
        <img src="/avatars/avatar-4.jpg" alt="" class="advisor-avatar" style="object-fit:cover;z-index:1;">
      </div>
      <div class="advisor-proof-text">
        <p><strong>140+ advisors</strong> joined the early access list.</p>
        <p>Priority access for early software testing.</p>
      </div>
    </div>
  </div>

  <!-- ═══ 3 PHONE MOCKUPS WITH ANIMATIONS ═══ -->
  <div class="mockup-area">
    <div class="mockup-blob-1"></div>
    <div class="mockup-blob-2"></div>

    <div class="phones-container">
      <!-- ── Recording Phone ── -->
      <div class="phone-frame phone-recording">
        <div class="phone-screen-content">
          <div class="phone-status-bar">
            <span>9:41</span>
            <span class="phone-status-icons">
              <span class="phone-status-battery"></span>
              <span class="phone-status-dot"></span>
            </span>
          </div>
          <div class="phone-chrome">
            <div class="chrome-header">
              <span class="chrome-back">&lt;</span>
              <span class="chrome-title">Recording</span>
              <span class="chrome-more">...</span>
            </div>
            <div class="chrome-body">
              <div class="inko-phone-scroll-recording">
                <div class="rec-header">
                  <div>
                    <p class="rec-name">Anna Johnson</p>
                    <p class="rec-subtitle">Policy Review Meeting</p>
                  </div>
                  <span class="rec-badge">REC</span>
                </div>
                <div style="margin-top:20px;text-align:center;">
                  <p id="rec-timer" style="font-size:1.48rem;font-weight:800;color:#17243a;font-variant-numeric:tabular-nums;">12:48</p>
                  <div class="waveform" id="rec-waveform">
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                    <span class="waveform-bar" style="height:4px;"></span>
                  </div>
                </div>
                <div class="live-transcript" style="margin-top:20px;">
                  <div class="live-transcript-header">
                    <span class="live-dot"></span>
                    Live Transcript
                  </div>
                  <p class="live-transcript-text">We want enough coverage for the kids, but the monthly payment needs to stay reasonable...</p>
                </div>
                <div class="signal-chips">
                  <span class="signal-chip">Family</span>
                  <span class="signal-chip">Life Insurance</span>
                  <span class="signal-chip">Budget Focus</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <img class="phone-frame-img" src="/phone-mockup.png" alt="">
      </div>

      <!-- ── Summary Phone ── -->
      <div class="phone-frame phone-summary">
        <div class="phone-screen-content">
          <div class="phone-status-bar">
            <span>9:41</span>
            <span class="phone-status-icons">
              <span class="phone-status-battery"></span>
              <span class="phone-status-dot"></span>
            </span>
          </div>
          <div class="phone-chrome">
            <div class="chrome-header">
              <span class="chrome-back">&lt;</span>
              <span class="chrome-title">Summary</span>
              <span class="chrome-more">...</span>
            </div>
            <div class="chrome-body">
              <div class="inko-phone-scroll-summary">
                <div class="sum-header">
                  <div>
                    <p class="sum-name">Anna Johnson</p>
                    <p class="sum-subtitle">Family Protection Review</p>
                  </div>
                  <span class="sum-badge">Summary Ready</span>
                </div>
                <div class="sum-cards">
                  <div class="sum-card">
                    <div class="sum-card-inner">
                      <span class="tone-icon tone-blue">.</span>
                      <div>
                        <h3 class="sum-card-title">Key Needs</h3>
                        <ul class="sum-card-items">
                          <li class="sum-card-item">- Family life coverage</li>
                          <li class="sum-card-item">- Protect education fund</li>
                          <li class="sum-card-item">- Keep monthly premium predictable</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                  <div class="sum-card">
                    <div class="sum-card-inner">
                      <span class="tone-icon tone-orange">!</span>
                      <div>
                        <h3 class="sum-card-title">Concerns</h3>
                        <ul class="sum-card-items">
                          <li class="sum-card-item">- Monthly budget sensitivity</li>
                          <li class="sum-card-item">- Wants clear comparison</li>
                          <li class="sum-card-item">- Before deciding</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                  <div class="sum-card">
                    <div class="sum-card-inner">
                      <span class="tone-icon tone-cyan">.</span>
                      <div>
                        <h3 class="sum-card-title">Decision Timeline</h3>
                        <ul class="sum-card-items">
                          <li class="sum-card-item">- Review in 2 weeks</li>
                          <li class="sum-card-item">- Check spouse comfort</li>
                          <li class="sum-card-item">- By Thursday</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                  <div class="sum-card">
                    <div class="sum-card-inner">
                      <span class="tone-icon tone-indigo">.</span>
                      <div>
                        <h3 class="sum-card-title">Client Signals</h3>
                        <ul class="sum-card-items">
                          <li class="sum-card-item">- Budget honest</li>
                          <li class="sum-card-item">- Family priority</li>
                          <li class="sum-card-item">- Needs simplicity</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                  <div class="sum-card">
                    <div class="sum-card-inner">
                      <span class="tone-icon tone-slate">&gt;</span>
                      <div>
                        <h3 class="sum-card-title">Next Best Action</h3>
                        <ul class="sum-card-items">
                          <li class="sum-card-item">- Send two quote options</li>
                          <li class="sum-card-item">- Schedule policy review</li>
                        </ul>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="sum-buttons">
                  <button class="sum-btn-primary">Generate Follow-up</button>
                  <button class="sum-btn-secondary">Ask Advisor</button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <img class="phone-frame-img" src="/phone-mockup.png" alt="">
      </div>

      <!-- ── Follow-up Phone ── -->
      <div class="phone-frame phone-followup">
        <div class="phone-screen-content">
          <div class="phone-status-bar">
            <span>9:41</span>
            <span class="phone-status-icons">
              <span class="phone-status-battery"></span>
              <span class="phone-status-dot"></span>
            </span>
          </div>
          <div class="phone-chrome">
            <div class="chrome-header">
              <span class="chrome-back">&lt;</span>
              <span class="chrome-title">Follow-up Ready</span>
              <span class="chrome-more">...</span>
            </div>
            <div class="chrome-body">
              <div class="inko-phone-scroll-followup">
                <div class="followup-draft">
                  <h3 class="followup-draft-title">Follow-up Draft</h3>
                  <p class="followup-draft-text">Hi Anna, great speaking with you today. I'll send two options that balance family protection with your monthly budget goal.</p>
                </div>

                <div style="margin-top:10px;">
                  <h3 class="followup-section-title">Next Steps</h3>
                  <div class="followup-steps">
                    <div class="followup-step">
                      <span class="followup-step-dot"><span class="followup-step-dot-inner"></span></span>
                      <span class="followup-step-text">Send quote comparison by Thursday</span>
                    </div>
                    <div class="followup-step">
                      <span class="followup-step-dot"><span class="followup-step-dot-inner"></span></span>
                      <span class="followup-step-text">Schedule policy review next week</span>
                    </div>
                    <div class="followup-step">
                      <span class="followup-step-dot"><span class="followup-step-dot-inner"></span></span>
                      <span class="followup-step-text">Confirm education fund priority</span>
                    </div>
                  </div>
                </div>

                <div style="margin-top:10px;">
                  <h3 class="followup-crm-title">CRM-ready Record</h3>
                  <div class="followup-crm-records">
                    <p class="followup-crm-record">Stage: Follow-up needed</p>
                    <p class="followup-crm-record">Tags: Family, Budget Focus</p>
                    <p class="followup-crm-record">Product Interest: 500k term target</p>
                  </div>
                </div>

                <div class="followup-buttons">
                  <button class="followup-btn-primary">Review &amp; Send</button>
                  <button class="followup-btn-secondary">Copy to CRM</button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <img class="phone-frame-img" src="/phone-mockup.png" alt="">
      </div>
    </div>
  </div>
</section>

<style is:global>
/* ── Hero Section ── */
.hero-section {
  max-width: 1160px; margin: 0 auto;
  display: grid; grid-template-columns: 0.88fr 1.18fr;
  align-items: center; gap: 2rem;
  padding: 4rem 2rem 4rem;
}
@media (max-width: 520px) { .hero-section { grid-template-columns: minmax(0, 1fr); padding: 4rem 1.25rem; text-align: center; } }
@media (min-width: 1024px) { .hero-section { padding-top: 6rem; padding-bottom: 6rem; } }
.hero-content {
  position: relative; z-index: 20; width: 100%; min-width: 0; max-width: 34rem; text-align: left;
}
@media (max-width: 520px) {
  .hero-content {
    width: calc(100vw - 2.5rem); max-width: calc(100vw - 2.5rem);
    margin-left: auto; margin-right: auto; text-align: center;
  }
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  margin-bottom: 2rem; border-radius: 999px;
  border: 1px solid #bfe7fb; background: #ecf8ff;
  padding: 0.375rem 0.75rem;
  font-size: 0.74rem; font-weight: 800; color: #1b86d5;
  box-shadow: 0 12px 26px -24px rgba(31,143,255,0.45);
}
.hero-badge-icon {
  display: flex; width: 16px; height: 16px; align-items: center; justify-content: center;
  border-radius: 999px; border: 1px solid #77cfff; font-size: 0.58rem;
}

.hero-h1 {
  max-width: 100%;
  font-size: 4rem; font-weight: 800; line-height: 1.03; letter-spacing: -0.03em; color: #050d19;
}
@media (max-width: 520px) { .hero-h1 { font-size: 2.2rem; line-height: 1.1; } }
@media (min-width: 1024px) { .hero-h1 { font-size: 4.42rem; } }
.hero-h1 em { font-style: normal; color: #1f8fff; }

.hero-sub {
  max-width: 496px; margin-top: 1.25rem;
  font-size: 1.08rem; font-weight: 500; line-height: 1.75; color: #101b2a;
}
@media (max-width: 520px) { .hero-sub { margin-left: auto; margin-right: auto; } }
@media (max-width: 520px) { .hero-sub { max-width: 20.5rem; font-size: 1rem; } }

/* ── Early Access Form ── */
.hero-form-wrap { margin-top: 1.5rem; }
.early-access-form {
  display: flex; width: 100%; max-width: 28rem; gap: 0.75rem;
}
@media (max-width: 520px) { .early-access-form { flex-direction: column; margin-left: auto; margin-right: auto; } }
.early-access-input {
  height: 52px; min-height: 52px; flex: 1;
  border-radius: 0.82rem; border: 1px solid #dbe8f4; background: rgba(255,255,255,0.92);
  padding: 0 1rem; font-size: 0.9rem; font-weight: 600; color: #17243a;
  box-shadow: 0 18px 42px -32px rgba(9,21,42,0.34); outline: none;
  transition: border-color 0.15s, box-shadow 0.15s;
  font-family: inherit;
}
.early-access-input::placeholder { color: #95a5b8; }
.early-access-input:focus { border-color: #1f8fff; box-shadow: 0 18px 42px -32px rgba(9,21,42,0.34), 0 0 0 4px #ccecff; }
@media (max-width: 520px) { .early-access-input { width: 100%; } }
.early-access-btn {
  height: 52px; min-height: 52px; border-radius: 0.82rem; border: none;
  background: #1f8fff; padding: 0 1.5rem;
  font-size: 0.86rem; font-weight: 800; color: #fff; cursor: pointer;
  box-shadow: 0 18px 38px -20px rgba(31,143,255,0.9); transition: background 0.15s;
  font-family: inherit; white-space: nowrap;
}
.early-access-btn:hover { background: #117dea; }
.early-access-btn:disabled { background: #8ccaff; cursor: not-allowed; }
@media (max-width: 520px) { .early-access-btn { width: 100%; } }
.form-message {
  flex-basis: 100%; font-size: 0.78rem; font-weight: 600; margin-top: 0.25rem;
}
.form-message.error { color: #c33b3b; }
.form-message.success { color: #1f8fff; }

/* ── Advisor Proof ── */
.advisor-proof {
  position: relative; z-index: 21;
  display: flex; align-items: center; gap: 0.85rem;
  width: 100%; max-width: 28rem;
  margin-top: 0.9rem;
  clear: both;
}
@media (max-width: 520px) {
  .advisor-proof {
    flex-direction: column; justify-content: center; align-items: center;
    gap: 0.5rem; margin-left: auto; margin-right: auto;
  }
}
.advisor-avatars { display: flex; padding-left: 0.5rem; }
.advisor-avatars .advisor-avatar {
  position: static; flex: 0 0 auto;
  display: block; width: 36px; height: 36px; border-radius: 999px;
  border: 2px solid #fff; background: #d9e9f7; background-size: cover; background-position: center;
  box-shadow: 0 12px 22px -16px rgba(10,23,51,0.45); margin-left: -8px;
}
.advisor-avatars .advisor-avatar:first-child { margin-left: 0; }
.advisor-proof-text { font-size: 0.76rem; line-height: 1.25rem; color: #162235; }
.advisor-proof-text strong { font-weight: 800; }
@media (max-width: 520px) { .advisor-proof-text { max-width: 18rem; text-align: center; } }

/* ── Product Mockups (3 phones) ── */
.mockup-area {
  position: relative; margin-top: 0; width: 100%; max-width: 38.5rem; margin-left: auto; margin-right: auto;
}
@media (max-width: 520px) { .mockup-area { margin-top: 2rem; max-width: 28rem; } }

.mockup-blob-1 {
  position: absolute; left: 3rem; right: 3rem; top: 2rem; height: 15rem;
  border-radius: 999px; background: #dff3ff; filter: blur(48px);
}
.mockup-blob-2 {
  position: absolute; left: 0; right: 0; bottom: 1.25rem; height: 4rem;
  border-radius: 999px; background: #d6ecff; filter: blur(16px);
}
.mockup-caption {
  position: absolute; left: 16%; top: 0; display: block; max-width: 12rem;
  transform: rotate(-8deg); text-align: center;
  font-size: 0.9rem; font-weight: 800; line-height: 1.25rem; color: #1f8fff;
  font-family: var(--font-newsreader);
}

.phones-container {
  position: relative; display: flex; min-height: 330px;
  align-items: flex-end; justify-content: center;
  gap: 0; transform: scale(0.93) translateZ(0);
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}
@media (min-width: 640px) { .phones-container { min-height: 390px; } }
@media (min-width: 1024px) { .phones-container { min-height: 435px; } }
@media (max-width: 520px) { .phones-container { transform: scale(0.86); } }

/* ── Phone Frame ── */
.phone-frame {
  position: relative; aspect-ratio: 430 / 879;
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
  -webkit-transform: translateZ(0);
  transform: translateZ(0);
}
.phone-frame-img {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  z-index: 10; pointer-events: none;
}
.phone-screen-content {
  position: absolute;
  top: 1.2%; left: 2.8%; right: 2.8%; bottom: 1.2%;
  z-index: 5; overflow: hidden;
  background: #fff;
  border-radius: 2.5rem / 2.5rem;
  display: flex; flex-direction: column;
}

.phone-status-bar {
  display: flex; height: 20px; flex-shrink: 0; align-items: center; justify-content: space-between;
  padding: 18px 16px 0; font-size: 0.42rem; font-weight: 800; color: #17243a;
  background: #fff; position: relative; z-index: 15;
}
.phone-status-icons { display: flex; align-items: center; gap: 4px; }
.phone-status-battery { height: 6px; width: 10px; border-radius: 3px; border: 1px solid #17243a; }
.phone-status-dot { height: 6px; width: 6px; border-radius: 999px; background: #17243a; }

.phone-chrome {
  display: flex; min-height: 0; flex: 1; flex-direction: column;
  background: linear-gradient(180deg, #ffffff 0%, #f7fbff 100%);
  padding: 4px 10px 0;
}
.phone-followup .phone-chrome {
  background: linear-gradient(180deg, #f5f9fd 0%, #edf4fb 100%);
}
.chrome-header {
  display: flex; margin-bottom: 8px; flex-shrink: 0; align-items: center; justify-content: space-between;
  color: #16233a;
}
.phone-summary .chrome-header { margin-top: 8px; }
.chrome-back { font-size: 0.65rem; font-weight: 800; }
.chrome-title { font-size: 0.56rem; font-weight: 800; }
.chrome-more { font-size: 0.62rem; color: #9badbf; }
.chrome-body { position: relative; min-height: 0; flex: 1; overflow: hidden; padding-bottom: 8px; }

/* ── Phone Sizes ── */
.phone-recording { width: 146px; transform: rotate(-4deg) translateZ(0); transform-origin: bottom left; }
.phone-summary { width: 168px; z-index: 20; transform: scale(1.02) translateZ(0); transform-origin: bottom; }
.phone-followup { width: 146px; transform: rotate(4deg) translateZ(0); transform-origin: bottom right; }
@media (min-width: 640px) {
  .phone-recording { width: 160px; }
  .phone-summary { width: 188px; }
  .phone-followup { width: 160px; }
}
@media (min-width: 1024px) {
  .phone-recording { width: 176px; transform: rotate(-4deg) translateY(28px) translateZ(0); }
  .phone-summary { width: 212px; }
  .phone-followup { width: 176px; transform: rotate(4deg) translateY(32px) translateZ(0); }
}
@media (max-width: 520px) {
  .phone-recording { width: 146px; }
  .phone-summary { width: 168px; }
  .phone-followup { width: 146px; }
}

/* ── Recording Phone Content ── */
.rec-header { display: flex; align-items: flex-start; justify-content: space-between; }
.rec-name { font-size: 0.68rem; font-weight: 800; color: #17243a; }
.rec-subtitle { margin-top: 2px; font-size: 0.43rem; font-weight: 600; color: #7d8ca0; }
.rec-badge {
  border-radius: 999px; background: #fff0f0; padding: 4px 6px;
  font-size: 0.4rem; font-weight: 800; color: #ff4d4d;
}
.rec-timer { margin-top: 20px; text-align: center; font-size: 1.48rem; font-weight: 800; color: #17243a; }

.waveform { display: flex; height: 48px; align-items: center; justify-content: center; gap: 2px; }
.waveform-bar {
  width: 2px; border-radius: 999px; background: #1f8fff;
  transition: height 0.14s cubic-bezier(0.22, 1, 0.36, 1);
}

.live-transcript {
  border-radius: 0.86rem; border: 1px solid #e6edf5; background: #fff;
  padding: 8px; box-shadow: 0 12px 28px -24px rgba(9,21,42,0.35);
}
.live-transcript-header {
  display: flex; margin-bottom: 6px; align-items: center; gap: 6px;
  font-size: 0.45rem; font-weight: 800; color: #495c72;
}
.live-dot { width: 10px; height: 10px; border-radius: 4px; background: #e8f4ff; }
.live-transcript-text { font-size: 0.43rem; line-height: 0.7rem; color: #7a8ba0; }

.signal-chips { display: flex; margin-top: 10px; flex-wrap: wrap; gap: 6px; }
.signal-chip {
  border-radius: 999px; background: #edf7ff; padding: 4px 6px;
  font-size: 0.38rem; font-weight: 800; color: #1d8dff;
}

/* ── Summary Phone Content ── */
.sum-header { display: flex; margin-bottom: 10px; align-items: flex-start; justify-content: space-between; gap: 8px; }
.sum-name { font-size: 0.74rem; font-weight: 800; color: #17243a; }
.sum-subtitle { margin-top: 2px; font-size: 0.45rem; font-weight: 600; color: #7d8ca0; }
.sum-badge {
  border-radius: 999px; background: #edf7ff; padding: 4px 6px;
  font-size: 0.38rem; font-weight: 800; color: #1d8dff; white-space: nowrap;
}
.sum-cards { display: flex; flex-direction: column; gap: 6px; }
.sum-card {
  border-radius: 0.75rem; border: 1px solid #e5edf6; background: #fff;
  padding: 6px 8px; box-shadow: 0 10px 26px -24px rgba(9,21,42,0.3);
}
.sum-card-inner { display: flex; gap: 8px; }
.tone-icon {
  flex-shrink: 0; display: flex; width: 14px; height: 14px;
  align-items: center; justify-content: center;
  border-radius: 5px; font-size: 0.42rem; font-weight: 800; margin-top: 2px;
}
.tone-blue { border: 1px solid #bfddff; background: #f0f8ff; color: #1f8fff; }
