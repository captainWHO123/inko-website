<script>
// ── Kit Form Submission ──
const KIT_FORM_URL = 'https://app.kit.com/forms/8899105/subscriptions';

function submitEmail(email: string): Promise<void> {
  return fetch(KIT_FORM_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: new URLSearchParams({ email_address: email }).toString(),
  }).then(() => {
    window.location.hash = '#/thank-you';
  });
}

function setupForm(formId: string, messageId: string) {
  const form = document.getElementById(formId) as HTMLFormElement | null;
  const msg = document.getElementById(messageId);
  if (!form) return;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
    if (!input || !input.value) return;
    const email = input.value.trim();
    if (!email) return;

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (btn) btn.disabled = true;

    submitEmail(email).catch(() => {
      if (msg) {
        msg.textContent = 'Something went wrong. Please try again.';
        msg.className = 'form-message error';
        msg.style.display = 'block';
      }
      if (btn) btn.disabled = false;
    });
  });
}

setupForm('hero-form', 'hero-form-message');
setupForm('hero-form-message', 'hero-form-message');

// ── Waveform Animation ──
const waveformBars = document.querySelectorAll('.waveform-bar');
const recTimer = document.getElementById('rec-timer');
let startTime = Date.now();

function animateWaveform() {
  const elapsed = (Date.now() - startTime) / 1000;
  waveformBars.forEach((bar, i) => {
    const height = 4 + Math.abs(Math.sin(elapsed * 2.5 + i * 0.7)) * 32;
    (bar as HTMLElement).style.height = height + 'px';
  });
  requestAnimationFrame(animateWaveform);
}
animateWaveform();

// ── Rec Timer ──
function updateTimer() {
  if (!recTimer) return;
  const elapsed = Math.floor((Date.now() - startTime) / 1000);
  const mins = Math.floor(elapsed / 60);
  const secs = elapsed % 60;
  recTimer.textContent = String(mins).padStart(2, '0') + ':' + String(secs).padStart(2, '0');
}
const timerInterval = setInterval(updateTimer, 1000);
updateTimer();
</script>
