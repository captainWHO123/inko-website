---
---
<section class="ask-advisor-overview" aria-label="Ask Advisor feature overview">
  <div class="ask-advisor-content">
    <h3 class="ask-advisor-title">Ask Advisor</h3>
    <p class="ask-advisor-subtitle">Understands everything about your clients and business and how to take the right action every time.</p>

    <div class="ask-advisor-grid">
      <div class="advisor-grid-column advisor-input-column">
        <h4 class="advisor-column-heading">Rich Inputs</h4>
        <p class="advisor-column-subtitle">Everything your AI agent learns from</p>
        <div class="advisor-card-stack">
          <article class="advisor-info-card advisor-info-card-large">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M5 6h14v10H8l-3 3V6Z"/><path d="M9 11h.01M12 11h.01M15 11h.01"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Conversation History</h4>
                <p class="advisor-card-body">All past calls, meeting, and notes.</p>
                <div class="advisor-note">
                  <p class="advisor-note-date">May 7 . 10:30 AM</p>
                  <p class="advisor-note-copy">Discussed policy option for family of 4, focusing on education fund and long-term protection.</p>
                </div>
              </div>
            </div>
          </article>

          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c2-5 14-5 16 0"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Client Profile</h4>
                <p class="advisor-card-body">Key details and relationships.</p>
                <div class="advisor-dots">
                  <span class="advisor-dot advisor-avatar-blue">AJ</span><span class="advisor-dot advisor-avatar-green">DL</span><span class="advisor-dot advisor-avatar-amber">MR</span><span class="advisor-dot advisor-avatar-violet">SK</span><span class="advisor-dot advisor-dot-plus">+</span>
                </div>
              </div>
            </div>
          </article>

          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M6 4h8a4 4 0 0 1 4 4v12H9a3 3 0 0 0-3 3V4Z"/><path d="M6 4h9a3 3 0 0 1 3 3"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Knowledge Base</h4>
                <p class="advisor-card-body">Your products, playbooks, and resources.</p>
                <div class="advisor-pills">
                  <span class="advisor-pill">Product Guide</span>
                  <span class="advisor-pill">Objection Handling</span>
                </div>
              </div>
            </div>
          </article>

          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M6 4h8a4 4 0 0 1 4 4v12H9a3 3 0 0 0-3 3V4Z"/><path d="M6 4h9a3 3 0 0 1 3 3"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Files &amp; Content</h4>
                <p class="advisor-card-body">Your products, playbooks, and resources.</p>
                <div class="advisor-pills">
                  <span class="advisor-pill advisor-file-pill">Plan.pdf</span>
                  <span class="advisor-pill advisor-file-pill">Family Protection.pptx</span>
                  <span class="advisor-pill advisor-file-pill">Plan Comparison.xlsx</span>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="advisor-connector-column">
        <svg class="advisor-connectors" viewBox="0 0 100 1000" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <marker id="advisor-soft-arrow-left-static" markerWidth="5" markerHeight="5" refX="4.5" refY="2.5" orient="auto" markerUnits="strokeWidth">
              <path d="M0 0 5 2.5 0 5Z" fill="#B7DFFF"></path>
            </marker>
          </defs>
          <g fill="none" stroke="#B7DFFF" stroke-linecap="round" stroke-linejoin="round" stroke-width="1" vector-effect="non-scaling-stroke">
            <path d="M0 215 H58"></path>
            <path d="M0 445 H58"></path>
            <path d="M0 625 H58"></path>
            <path d="M0 820 H58"></path>
            <path d="M58 215 V820"></path>
            <path d="M58 520 H100" marker-end="url(#advisor-soft-arrow-left-static)"></path>
          </g>
          <g fill="#B7DFFF">
            <circle cx="58" cy="520" r="2"></circle>
          </g>
        </svg>
      </div>

      <div class="advisor-phone-wrap advisor-grid-column">
        <div class="advisor-phone">
          <div class="advisor-phone-status"><span>9:41</span><span>...</span></div>
          <div class="advisor-phone-header"><span class="advisor-phone-back">&lt;</span><h4 class="advisor-phone-title">Ask Advisor</h4><span></span></div>
          <div class="advisor-question">What are the best next steps for Anna Johnson?</div>
          <div class="advisor-answer">
            <span class="advisor-avatar">AJ</span>
            <p class="advisor-answer-intro">Based on your conversations and client context, here's what I recommend:</p>
            <div class="advisor-task-list">
              <div class="advisor-task"><span class="advisor-task-number">1</span><div><p>Send a personalized follow-up email highlighting protection + education fund.</p><span class="advisor-mini-chip">Follow-up Email</span></div></div>
              <div class="advisor-task"><span class="advisor-task-number">2</span><div><p>Share a plan comparison focused on her budget and goals.</p><span class="advisor-mini-chip">Plan / Solution Match</span></div></div>
              <div class="advisor-task"><span class="advisor-task-number">3</span><div><p>Schedule a follow-up call next week to address policy details.</p><span class="advisor-mini-chip">Call Plan</span></div></div>
            </div>
            <div class="advisor-context">
              <span>2 Past Conversations</span><span>Client Profile</span><span>Family Protection Plan</span><span>Your Playbook</span><span>Knowledge Base</span>
            </div>
          </div>
          <div class="advisor-input-row"><span class="advisor-plus">+</span><div class="advisor-input-box"><span>Ask anything...</span><span>&gt;</span></div></div>
        </div>
      </div>

      <div class="advisor-connector-column">
        <svg class="advisor-connectors" viewBox="0 0 100 1000" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <marker id="advisor-soft-arrow-right-static" markerWidth="5" markerHeight="5" refX="4.5" refY="2.5" orient="auto" markerUnits="strokeWidth">
              <path d="M0 0 5 2.5 0 5Z" fill="#B7DFFF"></path>
            </marker>
          </defs>
          <g fill="none" stroke="#B7DFFF" stroke-linecap="round" stroke-linejoin="round" stroke-width="1" vector-effect="non-scaling-stroke">
            <path d="M100 225 H42"></path>
            <path d="M100 497 H42"></path>
            <path d="M100 695 H42"></path>
            <path d="M100 895 H42"></path>
            <path d="M42 225 V895"></path>
            <path d="M42 520 H0" marker-end="url(#advisor-soft-arrow-right-static)"></path>
          </g>
          <g fill="#B7DFFF">
            <circle cx="42" cy="520" r="2"></circle>
          </g>
        </svg>
      </div>

      <div class="advisor-grid-column advisor-output-column">
        <h4 class="advisor-column-heading">Smart Outputs</h4>
        <p class="advisor-column-subtitle">Created exactly for what you need</p>
        <div class="advisor-card-stack">
          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M4 6h16v12H4V6Z"/><path d="m4 7 8 7 8-7"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Follow-up Email</h4>
                <p class="advisor-card-body">Personalized and ready to send.</p>
                <div class="advisor-output-preview">
                  <div class="advisor-output-grid"><span>To:</span><span>Anna.johnson@gmail.com, david.johnson@gmail.com</span><span>Subject:</span><span>Recap: Preserving Flexibility While Funding Sophie's Education</span></div>
                  <div class="advisor-output-rule"></div>
                  <p>Hi Anna and David,</p><p style="margin-top:0.5rem;">Thank you again for meeting me for coffee this morning. It was a pleasure discussing the options...</p>
                  <div class="advisor-output-actions"><span style="background:#151515;">Copy</span><span style="background:#2fa0f6;">Send</span></div>
                </div>
              </div>
            </div>
          </article>

          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M6 4h9l3 3v13H6V4Z"/><path d="M15 4v4h4"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Plan/ Solution Match</h4>
                <p class="advisor-card-body">Best options for her goals.</p>
                <div class="advisor-table-preview"><div class="advisor-table-head"><span>Recommended</span><span>Coverage</span><span>Monthly</span><span>Match</span></div><div class="advisor-table-lines"><span></span><span></span><span></span></div></div>
              </div>
            </div>
          </article>

          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M4 5h16v11H4V5Z"/><path d="M12 16v4M8 20h8"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Presentation Slide</h4>
                <p class="advisor-card-body">Custom slide for your client.</p>
                <div class="advisor-slide-preview">
                  <div class="advisor-slide-card advisor-slide-card-blue">
                    <span class="advisor-slide-line" style="width:2.5rem;background:#2498ff;"></span>
                    <span class="advisor-slide-line" style="width:3.5rem;margin-top:0.5rem;"></span>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.25rem;margin-top:0.5rem;">
                      <span style="height:0.75rem;border-radius:0.25rem;background:#fff;"></span>
                      <span style="height:0.75rem;border-radius:0.25rem;background:#fff;"></span>
                    </div>
                  </div>
                  <div class="advisor-slide-card advisor-slide-card-soft">
                    <p class="advisor-slide-title">Plan Fit</p>
                    <div style="display:flex;height:1.5rem;align-items:flex-end;gap:0.25rem;margin-top:0.5rem;">
                      <span class="advisor-slide-bar" style="height:0.75rem;background:#b9dcff;"></span>
                      <span class="advisor-slide-bar" style="height:1.25rem;"></span>
                      <span class="advisor-slide-bar" style="height:1rem;background:#7ec8ff;"></span>
                    </div>
                  </div>
                  <div class="advisor-slide-card advisor-slide-card-warm">
                    <p class="advisor-slide-title">Next Step</p>
                    <div style="display:flex;flex-direction:column;gap:0.25rem;margin-top:0.5rem;">
                      <span class="advisor-slide-line" style="background:#ffc987;"></span>
                      <span class="advisor-slide-line" style="width:80%;background:#ffe1b8;"></span>
                      <span class="advisor-slide-line" style="width:60%;background:#ffe1b8;"></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </article>

          <article class="advisor-info-card">
            <div class="advisor-card-row">
              <span class="advisor-icon"><svg viewBox="0 0 24 24"><path d="M4 8h16M4 16h16"/><circle cx="9" cy="8" r="2"/><circle cx="15" cy="16" r="2"/></svg></span>
              <div>
                <h4 class="advisor-card-title">Anything You Need</h4>
                <p class="advisor-card-body">And whatever comes next</p>
                <div class="advisor-pills">
                  <span class="advisor-pill">Objection Handling</span><span class="advisor-pill">Renewal Strategy</span><span class="advisor-pill">Coverage Gap Analysis</span><span class="advisor-pill">...</span>
                </div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
/* -- Ask Advisor Overview -- */
.ask-advisor-overview {
  position: relative; max-width: 1160px; margin: 24px auto 0; overflow: hidden;
  border-radius: 1.15rem; background: #fff; padding: 2rem;
  box-shadow: 0 4px 16px rgba(0,0,0,0.1);
}
.ask-advisor-overview::after {
  content: ""; position: absolute; left: 0; right: 0; bottom: 0; height: 3rem; background: #fff;
}
.ask-advisor-content { position: relative; z-index: 1; }
.ask-advisor-title {
  font-family: "Space Grotesk", var(--font-inter); font-size: 1.52rem; font-weight: 700;
  line-height: 1.1; letter-spacing: 0.03em; color: #1E3A5F;
}
.ask-advisor-subtitle { margin-top: 0.7rem; font-size: 0.85rem; font-weight: 600; line-height: 1.38; color: #4A5568; }
.ask-advisor-grid {
  position: relative; margin-top: 2rem; display: grid;
  grid-template-columns: minmax(0,20rem) minmax(3rem,1fr) minmax(18rem,22rem) minmax(3rem,1fr) minmax(0,20rem);
  gap: 0;
}
.advisor-connectors {
  width: 100%; height: 100%; min-height: 48rem;
  overflow: visible; pointer-events: none;
}
.advisor-grid-column { position: relative; z-index: 3; }
.advisor-connector-column { position: relative; z-index: 4; }
.advisor-input-column { width: 100%; }
.advisor-output-column { width: 100%; }
.advisor-input-column .advisor-note { max-width: 100%; overflow: hidden; box-sizing: border-box; }
.advisor-input-column .advisor-note-copy { overflow-wrap: anywhere; }
.advisor-input-column .advisor-dots { max-width: 100%; flex-wrap: wrap; overflow: hidden; }
.advisor-input-column .advisor-pills { max-width: 100%; overflow: hidden; }
.advisor-input-column .advisor-pill { max-width: 100%; overflow-wrap: anywhere; }
.advisor-output-column .advisor-pills { max-width: 100%; overflow: hidden; }
.advisor-output-column .advisor-pill { max-width: 100%; overflow-wrap: anywhere; }
.advisor-column-heading { font-size: 1.25rem; font-weight: 700; line-height: 1.15; color: #2498ff; }
.advisor-column-subtitle { margin-top: 0.25rem; font-size: 0.85rem; font-weight: 600; line-height: 1.38; color: #8e9299; }
.advisor-card-stack { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
.advisor-info-card {
  position: relative; min-width: 0; border-radius: 1.25rem; border: 1px solid #ddd;
  background: #fff; padding: 1.25rem; box-shadow: 0 18px 36px -30px rgba(9,21,42,0.42);
}
.advisor-info-card-large { padding: 1.5rem; }
.advisor-card-row { display: flex; align-items: flex-start; gap: 1.25rem; }
.advisor-card-row > div { min-width: 0; flex: 1; }
.advisor-icon {
  width: 3rem; height: 3rem; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  border-radius: 999px; background: #f4faff; color: #2498ff;
}
.advisor-icon svg { width: 1.25rem; height: 1.25rem; stroke: currentColor; fill: none; stroke-width: 2; }
.advisor-card-title { font-size: 1rem; font-weight: 700; line-height: 1.15; color: #111417; }
.advisor-card-body { margin-top: 0.25rem; font-size: 0.85rem; font-weight: 600; line-height: 1.38; color: #4b4d52; }
.advisor-note {
  max-width: 16.7rem; margin: 1rem auto 0; border-radius: 0.5rem; border: 1px solid #e1e1e1;
  background: #fff; padding: 1.25rem; text-align: left;
}
.advisor-note-date { font-size: 0.72rem; font-weight: 600; line-height: 1.4; color: #8e9299; }
.advisor-note-copy { margin-top: 0.75rem; font-size: 0.85rem; font-weight: 600; line-height: 1.38; color: #111417; }
.advisor-dots { margin-top: 1rem; display: flex; align-items: center; gap: 0.75rem; }
.advisor-dot {
  width: 1.75rem; height: 1.75rem; border-radius: 999px; display: flex; align-items: center; justify-content: center;
  font-size: 0.62rem; font-weight: 600; line-height: 1.35; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.8);
}
.advisor-avatar-blue { background: linear-gradient(135deg,#dff3ff,#9ed6ff); color: #1477c9; }
.advisor-avatar-green { background: linear-gradient(135deg,#e8f7ee,#a8dec0); color: #267247; }
.advisor-avatar-amber { background: linear-gradient(135deg,#fff0df,#ffc987); color: #9a5a12; }
.advisor-avatar-violet { background: linear-gradient(135deg,#f0e9ff,#c9b7ff); color: #5d45b8; }
.advisor-dot-plus { display: flex; align-items: center; justify-content: center; background: #eaf6ff; color: #2498ff; }
.advisor-pills { margin-top: 1rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
.advisor-pill { border-radius: 0.5rem; background: #dff1ff; padding: 0.28rem 0.75rem; font-size: 0.72rem; font-weight: 600; line-height: 1.4; color: #2498ff; }
.advisor-file-pill { border: 1px solid #eee; background: #fff; color: #555; font-size: 0.62rem; line-height: 1.35; }
.advisor-phone-wrap { display: flex; align-items: flex-start; padding-top: 4.35rem; }
.advisor-phone {
  width: 100%; max-width: 22rem; margin: 0 auto; border-radius: 2rem; border: 1px solid #ddd;
  background: #fff; padding: 1rem 1.25rem 1.75rem; box-shadow: 0 16px 36px -34px rgba(9,21,42,0.4);
}
.advisor-phone-status { display: flex; align-items: center; justify-content: space-between; font-size: 1rem; font-weight: 700; color: #111417; }
.advisor-phone-header { margin-top: 1.5rem; display: flex; align-items: center; justify-content: space-between; }
.advisor-phone-back { font-size: 2rem; line-height: 1; }
.advisor-phone-title { font-size: 1rem; font-weight: 700; line-height: 1.15; color: #111417; }
.advisor-question { max-width: 16.2rem; margin: 1rem 0 0 auto; border-radius: 0.5rem; background: #2fa0f6; padding: 0.75rem 1rem; font-size: 0.85rem; font-weight: 600; line-height: 1.38; color: #fff; }
.advisor-answer {
  position: relative; margin-top: 3rem; border-radius: 1rem; border: 1px solid #edf1f5;
  background: #fff; padding: 1.5rem 1.25rem; box-shadow: 0 18px 42px -34px rgba(9,21,42,0.35);
}
.advisor-avatar {
  position: absolute; left: -1rem; top: -1.25rem; width: 2.75rem; height: 2.75rem;
  display: flex; align-items: center; justify-content: center; border-radius: 999px;
  background: #ddf2ff; color: #2498ff; font-size: 1rem; font-weight: 700;
}
.advisor-answer-intro { font-size: 0.72rem; font-weight: 600; line-height: 1.4; color: #34415a; }
.advisor-task-list { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 1.25rem; font-size: 0.72rem; font-weight: 600; line-height: 1.4; color: #34415a; }
.advisor-task { display: grid; grid-template-columns: 1.4rem 1fr; gap: 0.75rem; }
.advisor-task-number {
  width: 1.5rem; height: 1.5rem; display: flex; align-items: center; justify-content: center;
  border-radius: 999px; background: #ddecff; color: #2498ff; font-size: 0.72rem; font-weight: 600; line-height: 1.4;
}
.advisor-mini-chip { display: inline-block; margin-top: 0.5rem; border-radius: 0.5rem; background: #eef5ff; padding: 0.25rem 0.75rem; font-size: 0.62rem; font-weight: 600; line-height: 1.35; color: #5976a5; }
.advisor-context { margin-top: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
.advisor-context span { border-radius: 0.5rem; background: #e7f4ff; padding: 0.25rem 0.5rem; font-size: 0.62rem; font-weight: 600; line-height: 1.35; color: #2b89ff; }
.advisor-input-row { margin-top: 1rem; display: flex; align-items: center; gap: 0.75rem; }
.advisor-plus { width: 3rem; height: 3rem; display: flex; align-items: center; justify-content: center; border-radius: 999px; background: #eef9ff; font-size: 2rem; line-height: 1; color: #2498ff; }
.advisor-input-box { height: 3rem; flex: 1; display: flex; align-items: center; justify-content: space-between; border-radius: 999px; background: #f4fbff; padding: 0 1.25rem; font-size: 0.72rem; font-weight: 600; line-height: 1.4; color: #b9d8ef; }
.advisor-output-preview { max-width: 100%; overflow: hidden; margin-top: 1rem; border-radius: 0.5rem; background: #fff; padding: 0.75rem; font-size: 0.62rem; font-weight: 600; line-height: 1.35; color: #333; box-shadow: 0 14px 30px -24px rgba(9,21,42,0.35); }
.advisor-output-grid { display: grid; min-width: 0; grid-template-columns: 2rem minmax(0,1fr); gap: 0.5rem; }
.advisor-output-grid span { min-width: 0; overflow-wrap: anywhere; }
.advisor-output-rule { height: 1px; margin: 0.5rem 0; background: #eee; }
.advisor-output-actions { margin-top: 0.75rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }
.advisor-output-actions span { border-radius: 0.5rem; padding: 0.25rem 0; text-align: center; color: #fff; }
.advisor-table-preview { max-width: 100%; overflow: hidden; margin-top: 1rem; border-radius: 0.5rem; border: 1px solid #eee; background: #fff; padding: 0.75rem; font-size: 0.62rem; font-weight: 600; line-height: 1.35; color: #17243a; }
.advisor-table-head { display: grid; min-width: 0; grid-template-columns: repeat(4,minmax(0,1fr)); gap: 0.25rem; font-weight: 600; }
.advisor-table-head span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.advisor-table-lines { margin-top: 0.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
.advisor-table-lines span { height: 0.38rem; border-radius: 999px; background: #eef3f8; }
.advisor-slide-preview { max-width: 100%; margin-top: 1rem; display: flex; gap: 0.5rem; overflow: hidden; border-radius: 0.5rem; }
.advisor-slide-card {
  aspect-ratio: 16 / 10; min-width: 0; flex: 1 1 0;
  border-radius: 0.5rem; padding: 0.5rem; overflow: hidden;
}
.advisor-slide-card-blue { background: #eef7ff; }
.advisor-slide-card-soft { background: #f5faff; }
.advisor-slide-card-warm { background: #fff8ef; }
.advisor-slide-title { font-size: 0.62rem; font-weight: 600; line-height: 1.35; color: #1E3A5F; }
.advisor-slide-line { display: block; height: 0.38rem; border-radius: 999px; background: #bdddf5; }
.advisor-slide-bar { display: inline-block; width: 0.5rem; border-radius: 0.12rem; background: #2498ff; }
@media (max-width: 1024px) {
  .ask-advisor-grid { grid-template-columns: 1fr; }
  .advisor-connector-column { display: none; }
  .advisor-phone-wrap { padding-top: 0; }
}
@media (min-width: 1025px) {
  .advisor-input-column { max-width: 20rem; justify-self: start; }
  .advisor-phone-wrap { grid-column-start: 3; grid-row-start: 1; }
  .advisor-output-column { max-width: 20rem; justify-self: end; }
}
