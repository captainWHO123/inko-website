---
interface Props {
  title?: string;
}
const { title = 'Inko | Mobile Post-Conversation Workspace' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content="Inko turns insurance advisor meetings and calls into summaries, follow-up drafts, next steps, and client records.">
  <meta property="og:type" content="website">
  <meta property="og:title" content="Inko | Mobile Post-Conversation Workspace">
  <meta property="og:description" content="Turn every client conversation into a clear next step.">
  <meta property="og:image" content="/og-image.png">
  <meta property="og:url" content="https://get-inko.com">
  <meta name="twitter:card" content="summary_large_image">
  <!-- Google Analytics 4 -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-W5LCPJKRWB"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-W5LCPJKRWB');
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="canonical" href="https://get-inko.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <style is:global>
    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --font-inter: 'Manrope', Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      --font-newsreader: "Newsreader", "Iowan Old Style", "Palatino Linotype", Georgia, serif;
      --color-primary: #1f8fff;
      --color-primary-dark: #117dea;
      --color-primary-light: #ccecff;
    }
    html { scroll-behavior: smooth; }
    body {
      min-height: 100vh;
      font-family: var(--font-inter);
      letter-spacing: -0.01em;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    ::selection { background: rgba(159, 211, 201, 0.5); }
    .sr-only {
      position: absolute; width: 1px; height: 1px;
      padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); border: 0;
    }

    /* ── Layout ── */
    .stitch-homepage-viewport { background: #ffffff; }
    .stitch-homepage-canvas {
      font-family: var(--font-inter);
      background:
        radial-gradient(circle at 18% 10%, rgba(219,244,255,0.92), transparent 27%),
        radial-gradient(circle at 88% 16%, rgba(202,235,255,0.7), transparent 26%),
        linear-gradient(180deg, #fbfdff 0%, #f5fbff 35%, #ffffff 58%, #ffffff 100%);
      color: #0a1733;
      overflow: hidden;
    }
    @media (max-width: 900px) {
      .stitch-homepage-canvas { width: 900px; transform: none; zoom: calc(100vw / 900px); }
    }
    @media (max-width: 520px) {
      .stitch-homepage-canvas { width: 100%; zoom: 1; }
    }
    main { padding-top: 0; }

    /* ── Reduced Motion ── */
    @media (prefers-reduced-motion: reduce) {
      .inko-phone-scroll-recording,
      .inko-phone-scroll-summary,
      .inko-phone-scroll-followup { animation: none; }
      html { scroll-behavior: auto; }
    }
  </style>
  <slot name="head" />
</head>
<body>
  <div class="stitch-homepage-viewport">
    <div class="stitch-homepage-canvas">
      <slot />
    </div>
  </div>
  <slot name="overlay" />
  <script is:inline>
  (function() {
    function trackEvent(name, params) {
      if (typeof gtag === 'function') gtag('event', name, params);
    }

    // ── Section Visibility Tracking ──
    var sectionObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var el = entry.target;
          var name = el.id || el.className.split(' ')[0].replace('-section', '');
          trackEvent('section_view', { section_name: name });
          sectionObserver.unobserve(el);
        }
      });
    }, { threshold: 0.2 });
    document.querySelectorAll('section').forEach(function(s) { sectionObserver.observe(s); });

    // ── Scroll Depth Tracking (25%, 50%, 75%, 90%) ──
    var fired = {};
    window.addEventListener('scroll', function() {
      var h = document.documentElement.scrollHeight - window.innerHeight;
      if (h <= 0) return;
      var pct = Math.round((window.scrollY / h) * 100);
      [25, 50, 75, 90].forEach(function(m) {
        if (pct >= m && !fired[m]) {
          fired[m] = true;
          trackEvent('scroll_depth', { percent: String(m) });
        }
      });
    }, { passive: true });
  })();
  </script>
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
</body>
</html>
