---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Workflow from '../components/Workflow.astro';
import Outcomes from '../components/Outcomes.astro';
import Security from '../components/Security.astro';
import FAQ from '../components/FAQ.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import LegalPages from '../components/LegalPages.astro';
---

<Layout>
  <Header />

  <main>
    <Hero />
    <Features />
    <Workflow />
    <Outcomes />
    <Security />
    <FAQ />
    <FinalCTA />
    <Footer />
  </main>

  <LegalPages slot="overlay" />
</Layout>
