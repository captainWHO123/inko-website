# Cloudflare Pages Function secrets
# Set these in Cloudflare Pages -> Settings -> Variables and Secrets.
KIT_API_KEY="your_kit_api_key"
KIT_FORM_ID="your_kit_form_id"

# Analytics (optional — leave empty to disable)
# Get your GA4 Measurement ID from https://analytics.google.com
VITE_GA_MEASUREMENT_ID=""
# Get your GTM Container ID from https://tagmanager.google.com
# If GTM is set, GA will be loaded through GTM instead of directly.
VITE_GTM_ID=""
